rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'superadmin';
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol in ['admin', 'superadmin'];
    }

    function isPublicCommerce() {
      return resource.data.activo == true
        && (!('visibilidadEstado' in resource.data) || resource.data.visibilidadEstado == 'publicado');
    }

    function isMetricOnlyCommerceUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metricas'])
        && ('metricas' in request.resource.data)
        && request.resource.data.metricas.keys().hasOnly([
          'visitasFicha',
          'clicsWhatsapp',
          'clicsLlamar',
          'clicsMapa',
          'favoritos',
          'compartidos'
        ]);
    }

    function isPublicPublication() {
      return resource.data.activo == true
        && (!('moderacionEstado' in resource.data) || resource.data.moderacionEstado == 'approved');
    }

    function isValidPublicationEngagement(publicacionId) {
      return request.resource.data.keys().hasOnly(['publicationId', 'likesCount', 'commentsCount', 'comentarios', 'actualizadoEn'])
        && request.resource.data.publicationId == publicacionId
        && (!('likesCount' in request.resource.data) || (request.resource.data.likesCount is int && request.resource.data.likesCount >= 0 && request.resource.data.likesCount <= 1000000))
        && (!('commentsCount' in request.resource.data) || (request.resource.data.commentsCount is int && request.resource.data.commentsCount >= 0 && request.resource.data.commentsCount <= 1000000))
        && (!('comentarios' in request.resource.data) || (request.resource.data.comentarios is list && request.resource.data.comentarios.size() <= 200))
        && (!('actualizadoEn' in request.resource.data) || request.resource.data.actualizadoEn is string);
    }

    function isComercioOwner(comercioId) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.comercioId == comercioId && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'comercio';
    }

    function hasUsableSubscription(userId) {
      let profile = get(/databases/$(database)/documents/users/$(userId)).data;
      return !(profile.suscripcionEstado in ['expired', 'cancelled'])
        && (!('suscripcionVenceAt' in profile) || profile.suscripcionVenceAt > request.time);
    }

    function isValidOwnProfileCreate(userId) {
      return isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.id == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.activo == true
        && request.resource.data.rol in ['usuario', 'cliente', 'comercio']
        && (!('comercioId' in request.resource.data) || request.resource.data.comercioId == userId)
        && (request.resource.data.rol != 'comercio' || request.resource.data.comercioId == userId);
    }

    function isSafeOwnProfileUpdate(userId) {
      return isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre']);
    }

    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isAuthenticated() && isSuperAdmin();
      allow create: if isValidOwnProfileCreate(userId) || isSuperAdmin();
      allow update: if isSafeOwnProfileUpdate(userId) || isSuperAdmin();
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    match /comercios/{comercioId} {
      allow read: if isPublicCommerce() || isComercioOwner(comercioId) || isSuperAdmin();
      allow create: if (isComercioOwner(comercioId) && hasUsableSubscription(request.auth.uid)) || isSuperAdmin();
      allow update: if isMetricOnlyCommerceUpdate() || (isComercioOwner(comercioId) && hasUsableSubscription(request.auth.uid)) || isSuperAdmin();
      allow delete: if (isComercioOwner(comercioId) && hasUsableSubscription(request.auth.uid)) || isSuperAdmin();
    }

    match /publicaciones/{publicacionId} {
      allow read: if isPublicPublication() || isComercioOwner(resource.data.comercioId) || isSuperAdmin();
      allow create: if (isComercioOwner(request.resource.data.comercioId) && hasUsableSubscription(request.auth.uid)) || isSuperAdmin();
      allow update, delete: if (isComercioOwner(resource.data.comercioId) && hasUsableSubscription(request.auth.uid)) || isSuperAdmin();
    }

    match /publicacionInteracciones/{publicacionId} {
      allow read: if true;
      allow create, update: if isValidPublicationEngagement(publicacionId);
      allow delete: if isSuperAdmin();
    }

    match /categorias/{categoriaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /planes/{planId} {
      allow read: if resource.data.activo == true || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }
  }
}
