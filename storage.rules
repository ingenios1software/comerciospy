rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.rol in ['admin', 'superadmin'];
    }

    function isCommerceUser() {
      return isAuthenticated() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.rol == 'comercio';
    }

    function hasUsableSubscription(userId) {
      let profile = firestore.get(/databases/(default)/documents/users/$(userId)).data;
      return !(profile.suscripcionEstado in ['expired', 'cancelled'])
        && (!('suscripcionVenceAt' in profile) || profile.suscripcionVenceAt > request.time);
    }

    function isOwnerRequest() {
      return isAuthenticated() && request.resource != null && request.resource.metadata.owner == request.auth.uid;
    }

    function isOwnerResource() {
      return isAuthenticated() && resource != null && resource.metadata.owner == request.auth.uid;
    }

    function isPathOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    function isValidImage() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isValidPublicationMedia() {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
    }

    match /publicaciones/{ownerId}/{publicationId} {
      allow read: if true;
      allow create, update: if isValidPublicationMedia() && ((isPathOwner(ownerId) && isCommerceUser()) || isAdmin());
      allow delete: if (isPathOwner(ownerId) && hasUsableSubscription(ownerId)) || isAdmin();
    }

    match /publicaciones/{publicationId} {
      allow read: if true;
      allow create, update: if isValidPublicationMedia() && ((isOwnerRequest() && isCommerceUser()) || isAdmin());
      allow delete: if (isOwnerResource() && hasUsableSubscription(request.auth.uid)) || isAdmin();
    }

    match /comercios/{commerceId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isValidImage() && ((isOwnerRequest() && isCommerceUser()) || isAdmin());
      allow delete: if (isOwnerResource() && hasUsableSubscription(request.auth.uid)) || isAdmin();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
